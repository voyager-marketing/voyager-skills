{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["id", "agent", "description", "fixture", "expected", "verifier"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z][a-z0-9-]*-[0-9]{3}$" },
    "agent": { "type": "string" },
    "description": { "type": "string" },
    "fixture": { "type": "object" },
    "expected": { "type": "object" },
    "verifier": {
      "type": "string",
      "enum": ["exact_match", "structural_match", "claude_judge", "judge"]
    },
    "verifier_config": { "type": "object" },
    "judge_rubric": { "type": "string" }
  }
}
